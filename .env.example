# Database
POSTGRES_USER=avito_bot
POSTGRES_PASSWORD=changeme_secret
POSTGRES_DB=avito_bot_db
DATABASE_URL=postgresql+asyncpg://avito_bot:changeme_secret@db:5432/avito_bot_db

# Redis
REDIS_URL=redis://redis:6379/0

# Avito API
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_API_BASE_URL=https://api.avito.ru

# Email / SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Avito Bot

# App
SECRET_KEY=change-this-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
